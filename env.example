# Crimson-Heart 环境配置模板
# 1. 复制此文件为 .env
# 2. 将以下内容修改为你本地的实际路径

# [模型配置]
# 请修改为你的实际缓存目录，例如：./hf_cache
HF_HOME=./hf_cache

# [网络配置]
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# [VTS 配置]
VTS_HOST=localhost
VTS_PORT=8001

# [语音配置]
TTS_VOICE=zh-CN-XiaoxiaoNeural
WHISPER_MODEL_SIZE=medium

# [路径配置]
MEMORY_DB_PATH=data/chroma_db
LOG_PATH=data/dataset_alpaca.jsonl